<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Education</title>
<style>
  .education-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 auto;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    border: 1px solid #e0e0e0; /* Added border */
    border-radius: 8px;
  }
  .education-table td {
    padding: 20px;
    vertical-align: middle;
    border-bottom: 1px solid #f0f0f0;
  }
  .education-table img {
    border-radius: 50%;
    max-width: 100px;
    height: auto;
  }
  .education-table p {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
  }
  .education-table strong {
    font-weight: bold;
  }
  .education-table a {
    color: #007bff;
    text-decoration: none;
  }
  .education-table a:hover {
    text-decoration: underline;
  }
  .education-table .image-column {
    width: 20%;
  }
</style>
</head>
<body>

<table class="education-table">
  <tbody>
    <tr>
      <td class="image-column">
        <img src="assets/img/uoft.jpg" alt="University of Toronto" width="100" height="100">
      </td>
      <td>
        <p>
          <strong>University of Toronto</strong>
          <br>
          <a href="https://engsci.utoronto.ca/program/what-is-engsci/">BASc. in Engineering Science</a> | Sept. 2023 -- April 2027
          <br>
          <strong>Major: Machine Intelligence</strong>
          <br>
          <strong>Relevant courses:</strong> Probability & Statistics
        </p>
      </td>
    </tr>
  </tbody>
</table>

</body>
</html>

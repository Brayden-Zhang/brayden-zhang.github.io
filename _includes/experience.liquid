<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Experience</title>
<style>
  .experience-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  .experience-table td {
    padding: 20px;
    vertical-align: middle;
    border-bottom: 1px solid #f0f0f0;
  }
  .experience-table img {
    max-width: 100px;
    height: auto;
  }
  .experience-table p {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
  }
  .experience-table strong {
    font-weight: bold;
  }
  .experience-table a {
    color: #007bff;
    text-decoration: none;
  }
  .experience-table a:hover {
    text-decoration: underline;
  }
  .experience-table .image-column {
    width: 15%;
  }
</style>
</head>
<body>

<table class="experience-table">
  <tbody>
    <tr>
      <td class="image-column">
        <img src="assets/img/pair-logo-sq.png" alt="University of Toronto" width="100" height="100">
      </td>
      <td>
        <p>
          <strong>University of Toronto</strong>
          <br>
          <a>Robotics Research Intern</a> | April 2024 -- Present
          <br>
          <br>
        </p>
      </td>
    </tr>
    <tr>
      <td class="image-column">
        <img src="assets/img/ai_financial.jpg" alt="AI Financial" width="100" height="100">
      </td>
      <td>
        <p>
          <strong>AI Financial Power Group</strong>
          <br>
          <a>Software Engineering Intern</a> | July 2023 -- August 2023
          <br>
        </p>
      </td>
    </tr>
  </tbody>
</table>

</body>
</html>
